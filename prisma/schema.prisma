// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-1.1.x", "debian-openssl-3.0.x", "linux-musl"]
}

// generator erd {
//  provider = "prisma-erd-generator"
//  output   = "../ERD.png" 
// }

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// Users
model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  name         String
  role         Role     @default(USER)
  googleId     String   @unique
  accessToken  String?  @db.Text
  refreshToken String?  @db.Text
  
  news         News[]
  participated ActivityParticipant[]

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("users")
}

enum Role {
  USER
  ADMIN
}

enum NewsStatus {
  DRAFT
  PUBLISHED
}

// Jam Operasional
model OperationalHour {
  id        Int      @id @default(autoincrement())
  day       String   @unique
  open      String
  close     String
  isClosed  Boolean  @default(false)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("operational_hours")
}

// Berita
model News {
  id        Int      @id @default(autoincrement())
  title     String
  summary   String?  @db.Text
  content   String   @db.Text
  imageUrl  String?
  status    NewsStatus @default(DRAFT)
  
  authorId  Int
  author    User     @relation(fields: [authorId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("news")
}

// Kegiatan
model Activity {
  id          Int      @id @default(autoincrement())
  title       String
  description String   @db.Text
  startTime   DateTime
  endTime     DateTime

  participants ActivityParticipant[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("activities")
}

// Peserta Kegiatan
model ActivityParticipant {
  id         Int      @id @default(autoincrement())
  
  userId     Int
  activityId Int
  
  user       User     @relation(fields: [userId], references: [id])
  activity   Activity @relation(fields: [activityId], references: [id])

  joinedAt   DateTime @default(now())

  @@unique([userId, activityId])
  @@map("activity_participants")
}

// Lokasi Masjid (untuk integrasi Map Leaflet)
model MosqueLocation {
  id        Int      @id @default(autoincrement())
  name      String   // Nama masjid (cth: "Masjid As-Salam" atau nama masjid sekitar)
  address   String   @db.Text
  latitude  Float    // Koordinat lintang untuk Leaflet
  longitude Float    // Koordinat bujur untuk Leaflet
  imageUrl  String?  // Gambar thumbnail untuk bagian "masjid lain di sekitar"
  isMain    Boolean  @default(false) // true = Masjid utama, false = Masjid sekitar

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("mosque_locations")
}